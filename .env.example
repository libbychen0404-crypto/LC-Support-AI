# Required for Supabase-backed app execution
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for app auth session signing
AUTH_SESSION_SECRET=replace_with_a_long_random_secret

# Optional: enables live OpenAI wording and case-insight generation
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini

# Required if you want the homepage demo-entry buttons to work
DEMO_CUSTOMER_EMAIL=demo-customer@example.com
DEMO_CUSTOMER_PASSWORD=replace_with_demo_customer_password
DEMO_AGENT_EMAIL=demo-agent@example.com
DEMO_AGENT_PASSWORD=replace_with_demo_agent_password

# Optional: explicitly re-enable the seeded agent demo entry on a public production deployment
PUBLIC_AGENT_DEMO_ENTRY_ENABLED=false

# Required for the private internal agent demo login page
AGENT_DEMO_ACCESS_CODE=
